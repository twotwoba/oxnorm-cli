{
    "name": "oxcinit",
    "version": "0.1.0",
    "description": "A CLI tool to help developers quickly configure oxlint, oxfmt, husky, lint-staged, and commitlint",
    "type": "module",
    "bin": {
        "oxci": "./dist/index.js"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "tsup --watch",
        "build": "tsup",
        "preview": "node ./dist/index.js",
        "lint": "oxlint .",
        "format": "oxfmt --write .",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "keywords": [
        "cli",
        "oxlint",
        "oxfmt",
        "husky",
        "lint-staged",
        "commitlint",
        "oxc"
    ],
    "author": "",
    "license": "MIT",
    "engines": {
        "node": ">=18.18.0"
    },
    "dependencies": {
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "detect-package-manager": "^3.0.2",
        "execa": "^9.6.1",
        "figlet": "^1.11.0",
        "fs-extra": "^11.3.4",
        "gradient-string": "^3.0.0",
        "inquirer": "^13.3.2",
        "ora": "^9.3.0",
        "pathe": "^2.0.3",
        "semver": "^7.7.4"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^25.5.0",
        "@vitest/coverage-v8": "4.1.0",
        "oxfmt": "^0.41.0",
        "oxlint": "^1.56.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vite": "^8.0.0",
        "vitest": "^4.1.0"
    },
    "pnpm": {
        "overrides": {
            "string-width": "^7.2.0"
        }
    }
}
